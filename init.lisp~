(stumpwm:init-load-path "/home/thiago/.stumpwm.d/contrib")
(stumpwm:load-module "stumptray")

;; cores basicas ;;

(set-fg-color "black")
(set-bg-color "white")
(set-border-color "red")
(set-msg-border-width 3)

;; misc ;;

(set-prefix-key (kbd "s-RET"))
(setf *frame-number-map* "1234567890")
;(stumptray::stumptray)
(setf *mouse-focus-policy* :click)

;;  config da modeline  ;;

(setf *window-format* "%m%n%s%c")
(setf *screen-mode-line-format* (list "[^B%n^b] %W^>%d"))
(setf *time-modeline-string* "%a %b %e %k:%M")
(setf *mode-line-background-color* "black")
(setf *mode-line-foreground-color* "white")
(setf *mode-line-border-color* "white")
(setf *mode-line-border-width* 3)
(setf *mode-line-timeout* 2)

;; e finalmente, a modeline propriamente dita ;;

(enable-mode-line (current-screen) (current-head) t)

(stumpwm:run-commands
   "exec feh --bg-scale $HOME/Pictures/Gen/stum.png"
   "exec picom"
   "exec mpd"
)   

(stumpwm:run-commands
   "gnew 2"
   "gnew 3"
   "gnew 4"
   "gnew 5"
)   


;;   atalhos   ;;

(stumpwm:define-key stumpwm:*root-map* (stumpwm:kbd "s-f") "loadrc")

;;grupos

(stumpwm:define-key stumpwm:*groups-map* (stumpwm:kbd "s-1") "gselect 1")
(stumpwm:define-key stumpwm:*groups-map* (stumpwm:kbd "s-2") "gselect 2")
(stumpwm:define-key stumpwm:*groups-map* (stumpwm:kbd "s-3") "gselect 3")
(stumpwm:define-key stumpwm:*groups-map* (stumpwm:kbd "s-4") "gselect 4")
(stumpwm:define-key stumpwm:*groups-map* (stumpwm:kbd "s-5") "gselect 5")

